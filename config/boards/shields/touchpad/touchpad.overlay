/*
 * Standalone BLE Touchpad — HolyKeebs TPS43 + NRF52840 SuperMini
 *
 * Wiring:
 *   TPS43 adapter PCB    NRF52840 SuperMini (Pro Micro pinout)
 *   ─────────────────    ─────────────────────────────────────
 *   VCC  ─────────────►  VCC  (3.3V)
 *   GND  ─────────────►  GND
 *   SDA  ─────────────►  D2   (P0.17)
 *   SCL  ─────────────►  D3   (P0.20)
 *   RDY  ─────────────►  D4   (P0.22)  ← Required (interrupt)
 *
 * The AYM1607 driver is interrupt-driven — RDY pin is mandatory.
 */

/ {
    chosen {
        zmk,kscan = &mock_kscan;
    };

    /* Dummy kscan – no key matrix needed */
    mock_kscan: kscan {
        compatible = "zmk,kscan-mock";
        columns = <1>;
        rows = <1>;
        events = <0>;
        exit-after = <0>;
    };

    /* Input listener that connects touchpad data to ZMK's HID mouse */
    touchpad_listener: touchpad_listener {
        compatible = "zmk,input-listener";
        device = <&tps43>;
    };
};

&pro_micro_i2c {
    status = "okay";

    tps43: iqs5xx@74 {
        status = "okay";
        compatible = "azoteq,iqs5xx";
        reg = <0x74>;

        /* RDY pin — required for interrupt-driven operation */
        rdy-gpios = <&gpio0 22 GPIO_ACTIVE_HIGH>;

        /* RESET — optional, uncomment if wired to D5 */
        /* reset-gpios = <&gpio0 24 GPIO_ACTIVE_LOW>; */

        /* Gestures */
        one-finger-tap;
        two-finger-tap;
        press-and-hold;
        press-and-hold-time = <250>;

        /* Scrolling */
        scroll;
        natural-scroll-y;
        natural-scroll-x;

        /* Fine-tuning */
        bottom-beta = <5>;
        stationary-threshold = <5>;

        /*
         * Axis configuration — adjust based on orientation:
         *   switch-xy;    ← swap X/Y if touchpad is rotated 90°
         *   flip-x;       ← invert X
         *   flip-y;       ← invert Y
         */
    };
};
